# Ralph generated files (inside .ralph/ subfolder)
.ralph/.call_count
.ralph/.last_reset
.ralph/.exit_signals
.ralph/status.json
.ralph/.ralph_session
.ralph/.ralph_session_history
.ralph/.claude_session_id
.ralph/.response_analysis
.ralph/.circuit_breaker_state
.ralph/.circuit_breaker_history
.ralph/.last_output_length
.ralph/.loop_start_sha
.ralph/.token_count
.ralph/progress.json

# Ralph logs and generated docs
.ralph/logs/*
!.ralph/logs/.gitkeep
.ralph/docs/generated/*
!.ralph/docs/generated/.gitkeep

# Claude/StageFlow runtime state
.claude/audit.jsonl
.claude/current_stage.json
.claude/guard_violations.jsonl
.claude/benchmark_report.md
.claude/settings.local.json
.claude/settings.local.bak.json

# Python build/test artifacts
.coverage
.pytest_cache/
.mypy_cache/
*.egg-info/

# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/

# Node modules (if using Node.js projects)
node_modules/

# Python cache (if using Python projects)
__pycache__/
*.pyc

# Rust build (if using Rust projects)
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Ralph backup directories (created by migration)
.ralph_backup_*
